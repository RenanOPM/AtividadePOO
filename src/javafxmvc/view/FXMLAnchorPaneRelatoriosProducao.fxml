<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="590.0" prefWidth="980.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="javafxmvc.controller.FXMLAnchorPaneRelatoriosProducaoController">
  <children>
    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
      <children>
        <VBox styleClass="header">
          <children>
            <Label text="Relatório: Produção Detalhada" styleClass="header-title"/>
            <Label text="Listagem completa de produções com funcionário, gerente, lote e selagem — com filtros de período." styleClass="header-subtitle"/>
          </children>
        </VBox>

        <!-- KPIs -->
        <HBox spacing="12" style="-fx-padding:10 14 6 14;">
          <children>
            <VBox styleClass="kpi-card kpi-card-blue" alignment="CENTER">
              <children><Label fx:id="lblTotalProducoes" text="0" styleClass="kpi-value kpi-value-blue"/><Label text="Produções" styleClass="kpi-label"/></children>
            </VBox>
            <VBox styleClass="kpi-card kpi-card-green" alignment="CENTER">
              <children><Label fx:id="lblTotalLitros" text="0" styleClass="kpi-value kpi-value-green"/><Label text="Litros Totais" styleClass="kpi-label"/></children>
            </VBox>
            <VBox styleClass="kpi-card kpi-card-orange" alignment="CENTER">
              <children><Label fx:id="lblTotalEngradados" text="0" styleClass="kpi-value kpi-value-orange"/><Label text="Engradados" styleClass="kpi-label"/></children>
            </VBox>
          </children>
        </HBox>

        <!-- Filtros -->
        <VBox spacing="8" VBox.vgrow="ALWAYS">
          <padding><Insets top="4" right="14" bottom="14" left="14"/></padding>
          <children>
            <HBox spacing="10" styleClass="card" alignment="CENTER_LEFT" wrapLength="900">
              <children>
                <Label text="Tipo:" style="-fx-font-weight:bold;"/>
                <ComboBox fx:id="comboTipo" promptText="Todos" prefWidth="180" />
                <Label text="De:" style="-fx-font-weight:bold;"/>
                <DatePicker fx:id="dpInicio" promptText="dd/mm/aaaa" prefWidth="150"/>
                <Label text="Até:" style="-fx-font-weight:bold;"/>
                <DatePicker fx:id="dpFim" promptText="dd/mm/aaaa" prefWidth="150"/>
                <Button text="Filtrar" onAction="#carregar" styleClass="primary-button"/>
                <Button text="Limpar" onAction="#limparFiltro" styleClass="secondary-button"/>
              </children>
            </HBox>
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId"        text="#"          prefWidth="50"/>
                <TableColumn fx:id="colData"      text="Data"       prefWidth="100"/>
                <TableColumn fx:id="colTipo"      text="Tipo"       prefWidth="140"/>
                <TableColumn fx:id="colFuncionario" text="Funcionário" prefWidth="150"/>
                <TableColumn fx:id="colGerente"   text="Gerente"    prefWidth="130"/>
                <TableColumn fx:id="colLocal"     text="Local"      prefWidth="130"/>
                <TableColumn fx:id="colLitros"    text="Litros"     prefWidth="80"/>
                <TableColumn fx:id="colEngradados" text="Engradados" prefWidth="90"/>
                <TableColumn fx:id="colLote"      text="Lote"       prefWidth="120"/>
                <TableColumn fx:id="colSelagem"   text="Selagem ✓"  prefWidth="80"/>
              </columns>
            </TableView>
          </children>
        </VBox>
      </children>
    </VBox>
  </children>
</AnchorPane>
